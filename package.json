{
  "name": "brand-studio",
  "version": "1.0.0",
  "description": "Telegram bot for Brand Studio",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "dev:staging": "dotenv -e .env.staging -- tsx watch src/index.ts",
    "build": "tsc && cp src/prompts/*.md dist/prompts/",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@grammyjs/storage-redis": "^2.5.1",
    "@types/cheerio": "^0.22.35",
    "@types/pdf-parse": "^1.1.5",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.41.1",
    "ioredis": "^5.10.1",
    "openai": "^6.33.0",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^3.2.0",
    "postgres": "^3.4.8",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
